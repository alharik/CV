---

<footer role="contentinfo" class="footer-root relative px-6 py-32">
  <!-- Top separator -->
  <div class="footer-separator mx-auto max-w-6xl"></div>

  <div class="mx-auto max-w-6xl pt-20">
    <!-- Main 4-column grid -->
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-16">

      <!-- Column 1: Brand -->
      <div class="lg:col-span-1">
        <a
          href="#"
          class="footer-brand inline-block font-heading text-xl font-semibold tracking-[-0.02em]"
          style="color: var(--text-primary);"
        >
          {config.brand.name}
        </a>
        <p
          class="mt-4 max-w-[240px] text-[15px] leading-relaxed"
          style="color: var(--text-secondary);"
        >
          {config.brand.tagline}
        </p>
      </div>

      <!-- Dynamic columns (Navigation, Connect) -->
      {config.columns.map((column) => (
        <div>
          <h3
            class="footer-heading font-mono text-[11px] font-medium uppercase tracking-[0.15em]"
            style="color: var(--text-secondary);"
          >
            {column.heading}
          </h3>
          <ul class="mt-6 flex flex-col gap-3" role="list">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="footer-link text-[15px]"
                  {...(link.href.startsWith("http") || link.href.startsWith("mailto")
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Column 4: Socials -->
      <div>
        <h3
          class="footer-heading font-mono text-[11px] font-medium uppercase tracking-[0.15em]"
          style="color: var(--text-secondary);"
        >
          Socials
        </h3>
        <ul class="mt-6 flex flex-col gap-3" role="list">
          {config.socials.map((social) => (
            <li>
              <a
                href={social.href}
                class="footer-social-link inline-flex items-center gap-2.5 text-[15px]"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${social.label} (opens in new tab)`}
              >
                <svg
                  class="footer-social-icon"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d={social.pathD} />
                </svg>
                <span>{social.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom mt-20 flex flex-col items-center justify-between gap-4 pt-8 sm:flex-row">
      <p class="text-[13px]" style="color: var(--text-secondary);">
        {config.legal}
      </p>
      <p class="text-[13px] font-mono" style="color: var(--text-secondary);">
        Built with
        <a
          href="https://astro.build"
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          Astro
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  /* ── Footer root ─────────────────────────────────────────────── */
  .footer-root {
    background: var(--bg-surface);
  }

  /* ── Top separator line ──────────────────────────────────────── */
  .footer-separator {
    height: 0.5px;
    background: var(--glass-border);
  }

  /* ── Brand hover ─────────────────────────────────────────────── */
  .footer-brand {
    transition: color 400ms var(--ease-luxury);
  }

  .footer-brand:hover {
    color: var(--accent) !important;
  }

  /* ── Column headings ─────────────────────────────────────────── */
  .footer-heading {
    color: var(--text-secondary);
  }

  /* ── Navigation & connect links ──────────────────────────────── */
  .footer-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 400ms var(--ease-luxury);
  }

  .footer-link:hover {
    color: var(--accent);
  }

  /* ── Social links ────────────────────────────────────────────── */
  .footer-social-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 400ms var(--ease-luxury);
  }

  .footer-social-link:hover {
    color: var(--accent);
  }

  .footer-social-icon {
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 400ms var(--ease-luxury);
  }

  .footer-social-link:hover .footer-social-icon {
    opacity: 1;
  }

  /* ── Bottom bar separator ────────────────────────────────────── */
  .footer-bottom {
    border-top: 0.5px solid var(--glass-border);
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .footer-brand,
    .footer-link,
    .footer-social-link,
    .footer-social-icon {
      transition: none !important;
    }
  }
</style>
