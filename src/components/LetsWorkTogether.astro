<section id="cta" class="px-6 py-40">
  <div class="cta-wrapper mx-auto max-w-5xl text-center">

    <!-- DEFAULT STATE -->
    <div id="cta-default" class="cta-default-state">
      <!-- Availability badge -->
      <div data-reveal class="gsap-reveal mb-10 inline-flex items-center gap-2">
        <span class="cta-ping-wrapper">
          <span class="cta-ping-dot"></span>
          <span class="cta-ping-ring"></span>
        </span>
        <span class="font-mono text-sm uppercase tracking-wide" style="color: var(--text-secondary);">Available for projects</span>
      </div>

      <!-- Headline -->
      <h2 data-reveal class="gsap-reveal cta-headline mb-10 font-heading text-[clamp(2.5rem,6vw,4.5rem)] font-semibold leading-[1.1] tracking-[-0.02em]">
        <span style="color: var(--text-primary);">Let's work</span><br/>
        <span style="color: var(--text-secondary);">together</span>
      </h2>

      <!-- Decorative lines + arrow button -->
      <div data-reveal class="gsap-reveal cta-trigger-row mb-14 flex items-center justify-center gap-8">
        <span class="cta-line cta-line-left"></span>
        <button id="cta-trigger" class="cta-arrow-btn" aria-label="Get in touch">
          <span class="cta-arrow-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </span>
          <span class="cta-circle-ripple"></span>
        </button>
        <span class="cta-line cta-line-right"></span>
      </div>

      <!-- Paragraph -->
      <p data-reveal class="gsap-reveal mx-auto max-w-md" style="color: var(--text-secondary);">
        Have a project in mind? I'd love to hear about it. Let's create something exceptional together.
      </p>
    </div>

    <!-- SUCCESS STATE -->
    <div id="cta-success" class="cta-success-state">
      <span class="cta-success-label font-mono text-sm uppercase tracking-wide" style="color: var(--accent);">Perfect</span>
      <h2 class="cta-success-heading mb-10 mt-3 font-heading text-[clamp(2.5rem,6vw,4.5rem)] font-semibold leading-[1.1] tracking-[-0.02em]" style="color: var(--text-primary);">
        Let's talk
      </h2>

      <a
        id="cta-whatsapp"
        href="https://wa.me/971544117716?text=Hey!%20I%20just%20checked%20out%20your%20portfolio%20and%20loved%20the%20design.%20I%27d%20love%20to%20discuss%20working%20together%20%F0%9F%A4%9D"
        class="cta-whatsapp-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="cta-wa-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>
        </svg>
        <span class="cta-wa-text">Chat on WhatsApp</span>
        <svg class="cta-wa-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </a>

      <p class="cta-success-subtext mt-4 text-sm" style="color: var(--text-secondary);">Quick intro · No commitment</p>
    </div>

  </div>
</section>

<style is:global>
  /* -- Wrapper: relative for absolute success overlay -- */
  .cta-wrapper {
    position: relative;
    min-height: 360px;
  }

  /* -- Default state -- */
  .cta-default-state {
    position: relative;
    z-index: 1;
    transition: opacity 600ms var(--ease-luxury), transform 600ms var(--ease-luxury);
  }

  /* -- Success state: absolute overlay, always in DOM -- */
  .cta-success-state {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    transition: opacity 700ms var(--ease-luxury), transform 700ms var(--ease-luxury);
  }

  .cta-success-state.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* -- Staggered success children -- */
  .cta-success-label,
  .cta-success-heading,
  .cta-whatsapp-btn,
  .cta-success-subtext {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 500ms var(--ease-luxury), transform 500ms var(--ease-luxury);
  }

  .cta-success-state.is-visible .cta-success-label {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 100ms;
  }

  .cta-success-state.is-visible .cta-success-heading {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 250ms;
  }

  .cta-success-state.is-visible .cta-whatsapp-btn {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 200ms;
  }

  .cta-success-state.is-visible .cta-success-subtext {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 500ms;
  }

  /* -- Ping animation (availability dot) -- */
  .cta-ping-wrapper {
    position: relative;
    display: inline-block;
    width: 8px;
    height: 8px;
  }

  .cta-ping-dot {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--accent);
  }

  .cta-ping-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--accent);
    animation: cta-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes cta-ping {
    0% {
      transform: scale(1);
      opacity: 0.75;
    }
    75%, 100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  /* -- Headline -- */
  .cta-headline {
    transition: transform 500ms var(--ease-luxury);
    cursor: default;
  }

  /* -- Decorative lines: 3 states -- */
  .cta-line {
    display: block;
    height: 1px;
    width: 80px;
    background: var(--glass-border);
    opacity: 0.5;
    transform: scaleX(1);
    transition: transform 500ms var(--ease-luxury), opacity 500ms var(--ease-luxury);
  }

  .cta-line-left {
    transform-origin: right center;
  }

  .cta-line-right {
    transform-origin: left center;
  }

  /* State 2: Hover -> scaleX(1.5) opacity 1 */
  .cta-trigger-row.is-hovered .cta-line {
    transform: scaleX(1.5);
    opacity: 1;
  }

  /* State 3: Clicked -> scaleX(0) + translateX(+/-20px) opacity 0 */
  .cta-trigger-row.is-clicked .cta-line-left {
    transform: scaleX(0) translateX(-20px);
    opacity: 0;
  }

  .cta-trigger-row.is-clicked .cta-line-right {
    transform: scaleX(0) translateX(20px);
    opacity: 0;
  }

  /* -- Arrow button -- */
  .cta-arrow-btn {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: transparent;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 500ms var(--ease-luxury), color 500ms var(--ease-luxury), border-color 500ms var(--ease-luxury);
    flex-shrink: 0;
    overflow: hidden;
  }

  .cta-trigger-row.is-hovered .cta-arrow-btn {
    background: var(--accent);
    color: var(--bg-base);
    border-color: var(--accent);
  }

  /* Arrow icon — flies off on click */
  .cta-arrow-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 500ms var(--ease-luxury), opacity 500ms var(--ease-luxury);
  }

  .cta-trigger-row.is-clicked .cta-arrow-icon {
    transform: translate(100px, -100px) scale(0.5);
    opacity: 0;
  }

  /* Circle ripple — scales 3x and fades, 700ms */
  .cta-circle-ripple {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid var(--accent);
    opacity: 0;
    transform: scale(1);
    pointer-events: none;
  }

  .cta-circle-ripple.is-active {
    animation: cta-ripple 700ms ease-out forwards;
  }

  @keyframes cta-ripple {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }

  /* -- WhatsApp button -- */
  .cta-whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    color: var(--text-primary);
    background: transparent;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 500ms var(--ease-luxury), color 500ms var(--ease-luxury), border-color 500ms var(--ease-luxury);
  }

  .cta-wa-icon,
  .cta-wa-text,
  .cta-wa-arrow {
    transition: color 500ms var(--ease-luxury);
    color: var(--text-primary);
  }

  .cta-whatsapp-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .cta-whatsapp-btn:hover .cta-wa-icon,
  .cta-whatsapp-btn:hover .cta-wa-text,
  .cta-whatsapp-btn:hover .cta-wa-arrow {
    color: var(--bg-base);
  }

  /* -- Reduced motion -- */
  @media (prefers-reduced-motion: reduce) {
    .cta-ping-ring {
      animation: none;
    }

    .cta-line,
    .cta-arrow-icon,
    .cta-success-label,
    .cta-success-heading,
    .cta-whatsapp-btn,
    .cta-success-subtext,
    .cta-default-state,
    .cta-success-state {
      transition: none !important;
    }

    .cta-circle-ripple.is-active {
      animation: none;
    }
  }
</style>

<script>
  const trigger = document.getElementById("cta-trigger") as HTMLButtonElement | null;
  const triggerRow = document.querySelector(".cta-trigger-row") as HTMLElement | null;
  const defaultState = document.getElementById("cta-default") as HTMLElement | null;
  const successState = document.getElementById("cta-success") as HTMLElement | null;
  const ripple = document.querySelector(".cta-circle-ripple") as HTMLElement | null;

  if (trigger && triggerRow && defaultState && successState && ripple) {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    // --- State machine ---
    let isHovered = false;
    let isClicked = false;
    let showSuccess = false;

    // --- Hover tracking ---
    triggerRow.addEventListener("mouseenter", () => {
      if (isClicked) return;
      isHovered = true;
      triggerRow.classList.add("is-hovered");
    });

    triggerRow.addEventListener("mouseleave", () => {
      if (isClicked) return;
      isHovered = false;
      triggerRow.classList.remove("is-hovered");
    });

    // --- Click handler ---
    trigger.addEventListener("click", () => {
      if (isClicked) return;
      isClicked = true;

      // Apply clicked state to trigger row (lines + arrow)
      triggerRow.classList.remove("is-hovered");
      triggerRow.classList.add("is-clicked");

      // Fire circle ripple
      ripple.classList.add("is-active");

      if (prefersReducedMotion) {
        // Skip animations — show success immediately
        defaultState.style.opacity = "0";
        defaultState.style.pointerEvents = "none";
        successState.classList.add("is-visible");
        return;
      }

      // Fade out default state
      defaultState.style.opacity = "0";
      defaultState.style.transform = "translateY(-20px)";
      defaultState.style.pointerEvents = "none";

      // showSuccess fires 600ms after isClicked
      setTimeout(() => {
        showSuccess = true;
        successState.classList.add("is-visible");
      }, 600);
    });
  }
</script>
