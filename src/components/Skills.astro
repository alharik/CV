---
import { skills } from "../data/skills";
---

<section id="skills" class="px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <h2 data-reveal class="gsap-reveal mb-12 text-[2rem] font-semibold text-text-primary">Tech Stack</h2>
    <div class="flex flex-col gap-12">
      {skills.map((group) => (
        <div>
          <span data-reveal class="gsap-reveal mb-4 block text-xs uppercase tracking-widest text-text-muted">
            {group.category}
          </span>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span data-skill-chip class="gsap-reveal skill-chip inline-block rounded-lg bg-bg-surface px-4 py-2 text-sm text-text-primary transition-shadow duration-200">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .skill-chip:hover {
    box-shadow: 0 0 12px var(--accent-glow);
  }
</style>
