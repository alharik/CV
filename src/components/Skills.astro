---
---

<section id="skills" class="px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <h2 data-reveal class="gsap-reveal mb-16 text-center text-[2rem] font-semibold text-text-primary">Tech Stack</h2>

    <!-- Globe — the entire section visualization -->
    <div class="flex items-center justify-center">
      <div class="relative">
        <!-- Subtle red glow blob -->
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
          <div class="h-96 w-96 rounded-full bg-accent-glow blur-3xl"></div>
        </div>
        <canvas
          id="globe-canvas"
          class="relative z-10 h-[380px] w-[380px] cursor-grab active:cursor-grabbing sm:h-[460px] sm:w-[460px] md:h-[550px] md:w-[550px]"
        ></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  import { initGlobe } from "../scripts/globe";

  const canvas = document.getElementById("globe-canvas") as HTMLCanvasElement | null;
  if (canvas) {
    initGlobe(canvas);
  }
</script>
